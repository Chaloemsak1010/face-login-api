## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
## Source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.user-rtproto
*.usertasks

*.onnx

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
*.pidb
*.resources.forceserialization

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Log]s/
[Tt]est[Rr]esults/

# SpecFlow Generated Files
*.feature.cs

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# Generated user settings files
ChromeTrace.log
PerformanceReport.psess

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[尝]试/

# NUnit
/*.xml
*.log
*.sqlite
*.testsproj

# Visual Studio Product Archives
*.zip
*.tar
*.gz

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/gdbinit
!.vscode/keybindings.json

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*._proto
*.log
*.vspscc
*.vssscc
.builds
*.sublime-project
*.sublime-workspace

# Compiled XML serializers
*.XmlSerializers.dll

# Output of MSBuild publish command
publish/

# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Re]Sharper.user
*.DotSettings.user

# JustCode Analytics Settings
JustCodeProjectSettings.txt

# Red Gate developer tools
*.xmlreport

# NCrunch
_NCrunch_*
.*crunch*.bin
Ncrunch.KeyFile

# MightyMoose
*.mm.db
*.mm_workspace.db

# WebMatrix local db
App_Data/*.ldf
App_Data/*.mdf

# Microsoft Azure Web App publish settings. For easy access, user secrets should be used.
PublishProfiles/
*.pubxml
*.publishsettings

# OneDrive temporary files
.DS_Store

# Local History for Visual Studio Code
.history/

# Command Line Tools
.dotnet/
.tools/

# Paket dependency manager
.paket/

# F# ImagePlayground
wpf/ImagePlayground/bin/
wpf/ImagePlayground/obj/

# Tools
_tools/

# Entity Framework Core migrations SQL scripts
*.eh.sql
